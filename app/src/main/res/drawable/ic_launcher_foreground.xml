<?xml version="1.0" encoding="utf-8"?>
<!--
    앱 아이콘 포그라운드 — iOS icon_1024.png와 동일한 두 개의 흰색 pill
    뷰포트: 108x108dp (Android Adaptive Icon 표준)
    - 상단 pill: 왼쪽 정렬, 상단 1/3 위치 (iOS 아이콘과 동일)
    - 하단 pill: 오른쪽 정렬, 하단 2/3 위치
    배경(#1C87DE)은 ic_launcher_background.xml에서 담당
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 상단 pill (왼쪽 정렬) — iOS 아이콘 상단 pill과 동일 비율
         x=11, y=27, width=57, height=14, cornerRadius=7 (capsule) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M18,27
            H61
            A7,7 0 0 1 68,34
            A7,7 0 0 1 61,41
            H18
            A7,7 0 0 1 11,34
            A7,7 0 0 1 18,27
            Z"/>

    <!-- 하단 pill (오른쪽 정렬) — iOS 아이콘 하단 pill과 동일 비율
         x=40, y=65, width=57, height=14, cornerRadius=7 (capsule) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M47,65
            H90
            A7,7 0 0 1 97,72
            A7,7 0 0 1 90,79
            H47
            A7,7 0 0 1 40,72
            A7,7 0 0 1 47,65
            Z"/>

</vector>
