# local.properties.example
# мқҙ нҢҢмқјмқ„ local.propertiesлЎң ліөмӮ¬н•ҳкі  мӢӨм ң API нӮӨлҘј мһ…л Ҙн•ҳм„ёмҡ”.
# Copy this file to local.properties and fill in your actual API key.

# Google Cloud API Key (Speech-to-Text, Translation, Text-to-Speech)
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here

# Android SDK кІҪлЎң (мһҗлҸҷмңјлЎң м„Өм •лҗ©лӢҲлӢӨ)
# sdk.dir=/path/to/android/sdk
